{
  "name": "fpl-optimizer",
  "version": "1.0.0",
  "private": true,
  "description": "Fantasy Premier League optimization tool with XGBoost predictions and PuLP solver",
  "scripts": {
    "dev": "./dev.sh",
    "dev:backend": "cd backend && python3 -m uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "install:all": "cd frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "next-themes": "^0.4.6"
  }
}
